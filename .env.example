SECRET_KEY=change-me
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1
CSRF_TRUSTED_ORIGINS=

# Base de datos
# Dejar DB_NAME vacío usa SQLite (desarrollo local). Para producción con
# PostgreSQL, llenar las 5 variables de abajo.
DB_NAME=
DB_USER=
DB_PASSWORD=
DB_HOST=localhost
DB_PORT=5432

# Email (formulario de contacto)
# En desarrollo se puede dejar el backend de consola (imprime el correo en la terminal).
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=no-reply@cjhirashi.com
CONTACT_RECIPIENT_EMAIL=carlos@cjhirashi.com

# Seguridad en producción — dejar en False hasta confirmar que HTTPS
# (certbot) ya funciona en el dominio.
SECURE_SSL_REDIRECT=False
SESSION_COOKIE_SECURE=False
CSRF_COOKIE_SECURE=False
SECURE_HSTS_SECONDS=0
SECURE_HSTS_INCLUDE_SUBDOMAINS=False
SECURE_HSTS_PRELOAD=False
